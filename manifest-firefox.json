{
  "manifest_version": 3,
  "name": "Discord Age Encryption",
  "version": "0.1.0",
  "description": "End-to-end age encryption for Discord.",
  "data_collection_permissions": {
    "collected": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{19e0c78a-600a-4739-8977-56ca5741df7e}",
      "strict_min_version": "112.0",
      "update_url": "https://raw.githubusercontent.com/SenseiDeElite/discord-age-encryption/refs/heads/main/updates.json"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://discord.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*"
      ],
      "js": [
        "lib/age.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Discord Age Encryption"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "web_accessible_resources": []
}
